generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AIKnowledge {
  id        Int       @id @default(autoincrement())
  categoria String
  pregunta  String
  respuesta String
  keywords  String[]  @default([])
  activa    Boolean?  @default(true)
  prioridad Int?      @default(0)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model CompraTiktok {
  id                    Int      @id @default(autoincrement())
  nombreSolicitante     String
  emailSolicitante      String
  telefonoSolicitante   String
  nombreDestinatario    String
  carnetDestinatario    String
  direccionDestinatario String
  telefonoDestinatario  String
  linkTiktok            String
  descripcionProducto   String
  estado                String   @default("solicitado")
  notas                 String?
  precioProducto        Float    @default(0)
  precioEnvio           Float    @default(0)
  pesoEstimado          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model Config {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

model EmailLog {
  id        Int       @id @default(autoincrement())
  userId    Int?
  userEmail String
  asunto    String
  tipo      String?   @default("general")
  estado    String?   @default("enviado")
  error     String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  User      User?     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model Pedido {
  id                    Int      @id @default(autoincrement())
  nombreComprador       String
  emailComprador        String
  telefonoComprador     String
  nombreDestinatario    String
  telefonoDestinatario  String
  carnetDestinatario    String
  direccionDestinatario String
  producto              String
  notas                 String?
  plataforma            String?  // "tiktok", "amazon", "aliexpress", "shein", "mercadolibre", "otro"
  linkProducto          String?  // URL del producto en la plataforma externa
  estado                String   @default("pendiente")
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model TiendaProduct {
  id              Int       @id @default(autoincrement())
  nombre          String
  descripcion     String?
  precio          Float
  categoria       String?   @default("general")
  imagenUrl       String?
  tiktokUrl       String?
  amazonUrl       String?
  aliexpressUrl   String?
  sheinUrl        String?
  mercadoLibreUrl String?
  activo          Boolean?  @default(true)
  orden           Int?      @default(0)
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @db.Timestamp(6)
}

model TrackingEntry {
  id              Int      @id @default(autoincrement())
  cpk             String
  fecha           String?
  estado          String   @default("EN AGENCIA")
  descripcion     String?
  embarcador      String?
  consignatario   String?
  carnetPrincipal String?
  rawData         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
}

model User {
  id           Int         @id @default(autoincrement())
  nombre       String
  email        String      @unique
  telefono     String?
  password     String?
  direccion    String?
  ciudad       String?
  isActive     Boolean?    @default(true)
  registeredAt DateTime?   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?   @default(now()) @db.Timestamp(6)
  referralCode String?   @unique @db.VarChar(10)
  referrals    Referral[] @relation("Referrer")
  referredByReferrals Referral[] @relation("Referred")
  testimonios  Testimonio[]
  EmailLog     EmailLog[]
  visits       UserVisit[]
  presence     OnlinePresence[]
  services     ServiceListing[]
  notifications Notification[]
}

model Referral {
  id             Int      @id @default(autoincrement())
  referrerId     Int
  referredId     Int      @unique
  codigo         String   @db.VarChar(10)
  recompensa     String   @default("5% descuento")
  usado          Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamp(6)

  referrer       User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred       User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([codigo])
}

model Testimonio {
  id          Int      @id @default(autoincrement())
  userId      Int
  nombre      String
  texto       String
  rating      Int      @default(5)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activo])
}

model ServiceListing {
  id          Int      @id @default(autoincrement())
  tipo        String   @default("oferta") // "oferta" o "necesidad"
  titulo      String
  descripcion String?
  categoria   String   @default("general")
  ciudad      String?
  precio      String?  // texto libre: "$20", "Negociable", "Gratis"
  contacto    String?  // telefono, whatsapp, instagram, etc.
  imagenUrl   String?
  userId      Int
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tipo])
  @@index([categoria])
  @@index([userId])
  @@index([activo])
  @@index([createdAt])
}

model EmailLead {
  id        Int      @id @default(autoincrement())
  email     String
  nombre    String?
  source    String?  @default("popup")
 cupon     String?  @default("CHAMBA10")
 usado     Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@index([email])
  @@index([createdAt])
}

model UserVisit {
  id        Int      @id @default(autoincrement())
  userId    Int
  userAgent String?
  ip        String?
  page      String?  @default("/")
  createdAt DateTime @default(now()) @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])
}

model OnlinePresence {
  id        Int      @id @default(autoincrement())
  userId    Int
  sessionId String
  page      String?  @default("/")
  userAgent String?
  ip        String?
  lastSeen  DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([sessionId])
  @@index([userId])
  @@index([lastSeen])
}

model WebService {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("web")
  price       Float?
  image       String?
  tech        String?
  url         String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      Int?
  type        String   @default("status")
  title       String
  message     String
  pedidoId    Int?
  cpk         String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
